{
  "run_name": "pilot_smoke",
  "out_dir": "runs/pilot_smoke",
  "data_dir": "data/tokens",
  "seed": 1337,
  "device": "cuda",
  "dtype": "float16",
  "compile": false,

  "vocab_size": 257,
  "block_size": 128,
  "n_layer": 2,
  "n_head": 4,
  "n_embd": 128,
  "dropout": 0.0,
  "bias": false,

  "batch_size": 16,
  "gradient_accumulation_steps": 1,
  "max_iters": 50,
  "learning_rate": 0.0006,
  "min_lr": 0.00006,
  "warmup_iters": 5,
  "lr_decay_iters": 50,
  "weight_decay": 0.1,
  "beta1": 0.9,
  "beta2": 0.95,
  "grad_clip": 1.0,

  "eval_interval": 25,
  "eval_iters": 5,
  "log_interval": 1,
  "save_interval": 50,
  "sample_interval": 25,
  "sample_prompt": "Usuario: Hola Pilot\nPilot:",
  "sample_tokens": 80
}
